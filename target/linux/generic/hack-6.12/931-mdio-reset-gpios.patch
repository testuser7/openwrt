 /**
+ * mdiobus_get_reset_gpiods - Retrieve all reset GPIO descriptors for the MDIO bus
+ * @bus: target mii_bus
+ *
+ * Attempts to retrieve one or more reset GPIO descriptors from the device tree
+ * or firmware node. Stores them in bus->reset_gpiods array and updates 
+ * bus->reset_gpiods_count.
+ *
+ * Returns 0 on success, negative on error.
+ */
+static int mdiobus_get_reset_gpiods(struct mii_bus *bus)
+{
+	struct gpio_descs *gpiod_descs;
+	int i;
+
+	/* Try to get reset-gpios array from device tree */
+	gpiod_descs = devm_gpiod_get_array_optional(&bus->dev, "reset",
+						    GPIOD_OUT_HIGH);
+	if (IS_ERR(gpiod_descs))
+		return dev_err_probe(&bus->dev, PTR_ERR(gpiod_descs),
+				     "couldn't get reset GPIOs\n");
+
+	if (!gpiod_descs)
+		return 0;	/* No reset-gpios property found */
+
+	/* Allocate array to store individual GPIO descriptors */
+	bus->reset_gpiods = devm_kcalloc(&bus->dev, gpiod_descs->ndescs,
+					 sizeof(*bus->reset_gpiods),
+					 GFP_KERNEL);
+	if (!bus->reset_gpiods)
+		return -ENOMEM;
+
+	/* Copy GPIO descriptors from the array structure */
+	for (i = 0; i < gpiod_descs->ndescs; i++)
+		bus->reset_gpiods[i] = gpiod_descs->desc[i];
+
+	bus->reset_gpiods_count = gpiod_descs->ndescs;
+	return 0;
+}
+
+/**
+ * mdiobus_reset_assert - Assert all reset GPIOs for the MDIO bus
+ * @bus: target mii_bus
+ *
+ * Sets all reset GPIOs to active state (assert).
+ */
+static void mdiobus_reset_assert(struct mii_bus *bus)
+{
+	int i;
+
+	/* If we have multiple reset GPIOs, assert all of them */
+	if (bus->reset_gpiods && bus->reset_gpiods_count > 0) {
+		for (i = 0; i < bus->reset_gpiods_count; i++) {
+			if (bus->reset_gpiods[i])
+				gpiod_set_value_cansleep(bus->reset_gpiods[i], 1);
+		}
+	} else if (bus->reset_gpiod) {
+		/* Fall back to single reset GPIO for backward compatibility */
+		gpiod_set_value_cansleep(bus->reset_gpiod, 1);
+	}
+}
+
+/**
+ * mdiobus_reset_deassert - Deassert all reset GPIOs for the MDIO bus
+ * @bus: target mii_bus
+ *
+ * Sets all reset GPIOs to inactive state (deassert) with appropriate delays.
+ */
+static void mdiobus_reset_deassert(struct mii_bus *bus)
+{
+	int i;
+
+	/* If we have multiple reset GPIOs, deassert all of them */
+	if (bus->reset_gpiods && bus->reset_gpiods_count > 0) {
+		fsleep(bus->reset_delay_us);
+		for (i = 0; i < bus->reset_gpiods_count; i++) {
+			if (bus->reset_gpiods[i])
+				gpiod_set_value_cansleep(bus->reset_gpiods[i], 0);
+		}
+		if (bus->reset_post_delay_us > 0)
+			fsleep(bus->reset_post_delay_us);
+	} else if (bus->reset_gpiod) {
+		/* Fall back to single reset GPIO for backward compatibility */
+		fsleep(bus->reset_delay_us);
+		gpiod_set_value_cansleep(bus->reset_gpiod, 0);
+		if (bus->reset_post_delay_us > 0)
+			fsleep(bus->reset_post_delay_us);
+	}
+}
